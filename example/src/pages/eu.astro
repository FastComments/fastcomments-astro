---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodePanel from '../components/CodePanel.astro';
import { FastComments } from 'fastcomments-astro';

const code = `---
import { FastComments } from 'fastcomments-astro';
---

<FastComments tenantId="demo" region="eu" urlId="astro-demo-eu" />`;
---

<BaseLayout title="EU Region FastComments Astro">
  <div class="fc-demo">
    <header class="fc-demo__head">
      <div>
        <div class="fc-demo__breadcrumb">Flows <em>/ EU Region</em></div>
        <h1 class="fc-demo__title">EU Region</h1>
        <p class="fc-demo__subtitle">Pin widget reads and writes to the EU datacenter for data-residency requirements.
          A single <code style="font-family: var(--fc-mono); color: var(--fc-ink);">region="eu"</code> flag routes
          everything through the EU cluster.</p>
      </div>
      <div class="fc-demo__actions">
        <span class="fc-tag fc-tag--brand">Region · EU</span>
        <span class="fc-tag">GDPR-friendly</span>
      </div>
    </header>
    <div class="fc-stage__panel fc-stage__panel--light">
      <FastComments tenantId="demo" region="eu" urlId="astro-demo-eu" />
    </div>

    <CodePanel label="src/pages/eu.astro" code={code} />
  </div>
</BaseLayout>
