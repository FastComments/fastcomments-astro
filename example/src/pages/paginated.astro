---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodePanel from '../components/CodePanel.astro';
import { FastComments } from 'fastcomments-astro';

const code = `---
import { FastComments } from 'fastcomments-astro';
---

<button id="prev">Prev</button>
<button id="next">Next</button>
<div id="fc-slot">
  <FastComments tenantId="demo" urlId="product-0" />
</div>

<script>
  let page = 0;
  const slot = document.getElementById('fc-slot');
  const update = (d) => {
    page += d;
    // Paginated widgets typically swap urlId via the widget instance \`update()\`
    // method. Grab the instance from the global registry and call update.
    const inst = window.__fcInstances?.[0]?.inst;
    inst?.update?.({ tenantId: 'demo', urlId: 'product-' + page });
  };
  document.getElementById('prev').addEventListener('click', () => update(-1));
  document.getElementById('next').addEventListener('click', () => update(1));
</script>`;
---

<BaseLayout title="Thread Pagination FastComments Astro">
  <div class="fc-demo">
    <header class="fc-demo__head">
      <div>
        <div class="fc-demo__breadcrumb">Flows <em>/ Thread Pagination</em></div>
        <h1 class="fc-demo__title">Thread Pagination</h1>
        <p class="fc-demo__subtitle">Swap the widget&rsquo;s
          <code style="font-family: var(--fc-mono); color: var(--fc-ink);">urlId</code>
          at runtime to jump between products, posts, or pages. Threads provision lazily. No pre-creation needed.</p>
      </div>
      <div class="fc-demo__actions">
        <span class="fc-tag fc-tag--brand">Product · <span id="fc-page">0</span></span>
      </div>
    </header>

    <div class="fc-stage__panel" style="padding: 20px;">
      <div style="display: flex; align-items: center; gap: 10px; padding-bottom: 14px; box-shadow: inset 0 -1px 0 0 var(--fc-border); margin-bottom: 20px; flex-wrap: wrap;">
        <button class="fc-btn" id="fc-prev">← prev product</button>
        <button class="fc-btn fc-btn--primary" id="fc-next">next product →</button>
      </div>
      <div class="fc-stage__panel fc-stage__panel--light" style="padding: 20px;">
        <FastComments tenantId="demo" urlId="astro-product-0" />
      </div>
    </div>

    <CodePanel label="src/pages/paginated.astro" code={code} />
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    let page = 0;
    const pageLabel = document.getElementById('fc-page');
    const update = (d) => {
      page += d;
      if (pageLabel) pageLabel.textContent = String(page);
      const entry = (window.__fcInstances || []).find((e) => (e.base && e.base.urlId || '').startsWith('astro-product-'));
      if (entry) {
        const merged = { ...entry.base, urlId: 'astro-product-' + page };
        entry.inst.update(merged);
        entry.base = merged;
      }
    };
    document.getElementById('fc-prev')?.addEventListener('click', () => update(-1));
    document.getElementById('fc-next')?.addEventListener('click', () => update(1));
  })();
</script>
