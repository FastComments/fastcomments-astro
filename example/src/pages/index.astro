---
import BaseLayout from '../layouts/BaseLayout.astro';

const widgets = [
  { href: "/comments", label: "Live Comment Widget", kind: "widget", hint: "Full live commenting widget with replies, voting, moderation, and media." },
  { href: "/comment-count", label: "Comment Count", kind: "widget", hint: "Drop-in count badge for any listing or feed." },
  { href: "/live-chat", label: "Live Chat", kind: "widget", hint: "High-velocity streaming chat for live events." },
  { href: "/collab-chat", label: "Collab Chat", kind: "widget", hint: "Anchor threads to text selections inside articles." },
  { href: "/image-chat", label: "Image Chat", kind: "widget", hint: "Pin discussions to specific regions of any image." },
  { href: "/recent-comments", label: "Recent Comments", kind: "widget", hint: "Cross-site stream of the latest comments on a tenant." },
  { href: "/recent-discussions", label: "Recent Discussions", kind: "widget", hint: "The most active threads on a tenant, ranked by activity." },
  { href: "/top-pages", label: "Top Pages", kind: "widget", hint: "Pages ranked by comment activity." },
  { href: "/reviews-summary", label: "Reviews Summary", kind: "widget", hint: "Star-rating aggregate with breakdown." },
  { href: "/user-activity-feed", label: "Activity Feed", kind: "widget", hint: "A single user's chronological activity stream." },
];

const flows = [
  { href: "/dark-mode", label: "Dark Mode", kind: "flow", hint: "Toggle the widget theme at runtime via the hasDarkBackground flag." },
  { href: "/eu", label: "EU Region", kind: "flow", hint: "Pin widget reads and writes to the EU datacenter." },
  { href: "/paginated", label: "Thread Pagination", kind: "flow", hint: "Swap urlId at runtime to jump between products, posts, or pages." },
  { href: "/simple-sso", label: "Simple SSO", kind: "flow", hint: "Unsigned identity flow. Drop in a user object and go." },
  { href: "/secure-sso", label: "Secure SSO", kind: "flow", hint: "HMAC-signed identity from your server for production use." },
];
---

<BaseLayout title="FastComments Astro Showcase">
  <div class="fc-hero">
    <div>
      <div class="fc-hero__label">fastcomments / astro · showcase</div>
      <h1 class="fc-hero__title">Comment<br />infrastructure<br /><em>for Astro.</em></h1>
      <p class="fc-hero__body">
        Every component exported by <code style="font-family: var(--fc-mono); color: var(--fc-ink);">fastcomments-astro</code>,
        rendered live against the public demo tenant. Each route is a minimal Astro page you can copy into your own
        content collection.
      </p>
    </div>

    <div class="fc-hero__meta">
      <div class="fc-meta-card">
        <div class="fc-meta-card__key">Widgets</div>
        <div class="fc-meta-card__value fc-meta-card__value--gradient">{widgets.length}</div>
      </div>
      <div class="fc-meta-card">
        <div class="fc-meta-card__key">Flows</div>
        <div class="fc-meta-card__value">{flows.length}</div>
      </div>
      <div class="fc-meta-card">
        <div class="fc-meta-card__key">Package</div>
        <div class="fc-meta-card__value" style="font-family: var(--fc-mono); font-size: 14px; margin-top: 10px;">fastcomments-astro</div>
      </div>
      <div class="fc-meta-card">
        <div class="fc-meta-card__key">Rendering</div>
        <div class="fc-meta-card__value" style="font-family: var(--fc-mono); font-size: 14px; margin-top: 10px;">Static / Hybrid</div>
      </div>
    </div>
  </div>

  <div class="fc-section-title">
    <span>01</span>
    <h2>Widgets</h2>
    <div class="fc-rule"></div>
    <span>{widgets.length} components</span>
  </div>
  <div class="fc-grid">
    {widgets.map((item, i) => (
      <a class="fc-card" href={item.href} style={`animation: fc-rise 480ms ease both; animation-delay: ${i * 40}ms;`}>
        <span class="fc-card__kind">{item.kind}</span>
        <span class="fc-card__title">{item.label}</span>
        <span class="fc-card__hint">{item.hint}</span>
        <span class="fc-card__cta">Open example</span>
      </a>
    ))}
  </div>

  <div class="fc-section-title">
    <span>02</span>
    <h2>Flows &amp; configuration</h2>
    <div class="fc-rule"></div>
    <span>{flows.length} recipes</span>
  </div>
  <div class="fc-grid">
    {flows.map((item, i) => (
      <a class="fc-card" href={item.href} style={`animation: fc-rise 480ms ease both; animation-delay: ${i * 40}ms;`}>
        <span class="fc-card__kind">{item.kind}</span>
        <span class="fc-card__title">{item.label}</span>
        <span class="fc-card__hint">{item.hint}</span>
        <span class="fc-card__cta">Open example</span>
      </a>
    ))}
  </div>

  <style is:global>
    @keyframes fc-rise {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</BaseLayout>
