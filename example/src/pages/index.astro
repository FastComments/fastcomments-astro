---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="FastComments Astro Examples">
  <h1>FastComments Astro Examples</h1>
  <p>This project demonstrates each component exported by <code>fastcomments-astro</code>. Click a link below to see the component in action.</p>

  <ul>
    <li><a href="/comments">FastComments</a> — Full commenting widget</li>
    <li><a href="/comment-count">FastCommentsCommentCount</a> — Display the comment count for a page</li>
    <li><a href="/image-chat">FastCommentsImageChat</a> — Comment on regions of an image</li>
    <li><a href="/live-chat">FastCommentsLiveChat</a> — Real-time live chat widget</li>
    <li><a href="/collab-chat">FastCommentsCollabChat</a> — Collaborative chat on page content</li>
    <li><a href="/reviews-summary">FastCommentsReviewsSummary</a> — Star-rating reviews summary</li>
    <li><a href="/user-activity-feed">FastCommentsUserActivityFeed</a> — Activity feed for a user</li>
  </ul>
</BaseLayout>
